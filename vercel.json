{
  "version": 2,
  "builds": [
    { "src": "api/contact.js", "use": "@vercel/node" },
    { "src": "*.html", "use": "@vercel/static" },
    { "src": "styles.css", "use": "@vercel/static" },
    { "src": "script.js", "use": "@vercel/static" },
    { "src": "favicon.png", "use": "@vercel/static" },
    { "src": "*.jpg", "use": "@vercel/static" },
    { "src": "*.jpeg", "use": "@vercel/static" },
    { "src": "*.png", "use": "@vercel/static" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; connect-src 'self'; img-src 'self' data: blob:;"
        }
      ]
    }
  ],
  "routes": [
    { "src": "^/api/contact$", "dest": "/api/contact.js" },
    { "src": "^/$", "dest": "/index.html" },
    { "src": "^/favicon.ico$", "dest": "/favicon.png" },
    { "handle": "filesystem" }
  ]
}
